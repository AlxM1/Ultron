{
  "name": "Service Health Monitoring",
  "description": "Monitors all Ultron services every 5 minutes and alerts on failures",
  "nodes": [
    {
      "id": "trigger_1",
      "type": "ScheduleTrigger",
      "position": { "x": 100, "y": 100 },
      "parameters": {
        "cronExpression": "*/5 * * * *",
        "timezone": "America/Vancouver"
      }
    },
    {
      "id": "check_agentsmith",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 100 },
      "parameters": {
        "url": "http://localhost:4000/health/live",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "check_cortex",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 200 },
      "parameters": {
        "url": "http://localhost:3011/health",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "check_postgres",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 300 },
      "parameters": {
        "url": "http://localhost:5432",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true,
        "expectedStatus": [0, 200, 404, 502]
      }
    },
    {
      "id": "check_redis",
      "type": "Command",
      "position": { "x": 300, "y": 400 },
      "parameters": {
        "command": "docker exec raiser-redis redis-cli -a \"$REDIS_PASSWORD\" ping",
        "continueOnFail": true
      }
    },
    {
      "id": "check_youtubedl",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 500 },
      "parameters": {
        "url": "http://localhost:8200/docs",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "check_persona",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 600 },
      "parameters": {
        "url": "http://localhost:8500/docs",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "check_whisperflow",
      "type": "HttpRequest",
      "position": { "x": 300, "y": 700 },
      "parameters": {
        "url": "http://localhost:8766/api/health",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "aggregate_results",
      "type": "Function",
      "position": { "x": 500, "y": 400 },
      "parameters": {
        "functionCode": "const services = [\n  { name: 'AgentSmith', result: $node['check_agentsmith'] },\n  { name: 'Cortex', result: $node['check_cortex'] },\n  { name: 'Postgres', result: $node['check_postgres'] },\n  { name: 'Redis', result: $node['check_redis'] },\n  { name: 'YouTubeDL', result: $node['check_youtubedl'] },\n  { name: 'Persona Pipeline', result: $node['check_persona'] },\n  { name: 'WhisperFlow', result: $node['check_whisperflow'] }\n];\n\nconst failures = services.filter(s => \n  !s.result || s.result.error || (s.result.statusCode && s.result.statusCode >= 500)\n);\n\nconst healthy = services.filter(s => \n  s.result && !s.result.error && (!s.result.statusCode || s.result.statusCode < 500)\n);\n\nreturn {\n  timestamp: new Date().toISOString(),\n  totalServices: services.length,\n  healthy: healthy.length,\n  failed: failures.length,\n  failures: failures.map(f => ({ \n    name: f.name, \n    error: f.result?.error || f.result?.statusCode \n  })),\n  status: failures.length > 0 ? 'degraded' : 'healthy'\n};"
      }
    },
    {
      "id": "check_if_failures",
      "type": "If",
      "position": { "x": 700, "y": 400 },
      "parameters": {
        "condition": "{{ $json.failed > 0 }}"
      }
    },
    {
      "id": "send_alert",
      "type": "HttpRequest",
      "position": { "x": 900, "y": 300 },
      "parameters": {
        "url": "http://localhost:3011/api/tasks",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "task_type": "health_alert",
          "priority": "high",
          "data": "{{ $json }}"
        }
      }
    },
    {
      "id": "log_healthy",
      "type": "Function",
      "position": { "x": 900, "y": 500 },
      "parameters": {
        "functionCode": "console.log('[Health Check] All services healthy:', $json.timestamp);\nreturn $json;"
      }
    }
  ],
  "connections": [
    { "source": "trigger_1", "target": "check_agentsmith" },
    { "source": "trigger_1", "target": "check_cortex" },
    { "source": "trigger_1", "target": "check_postgres" },
    { "source": "trigger_1", "target": "check_redis" },
    { "source": "trigger_1", "target": "check_youtubedl" },
    { "source": "trigger_1", "target": "check_persona" },
    { "source": "trigger_1", "target": "check_whisperflow" },
    { "source": "check_agentsmith", "target": "aggregate_results" },
    { "source": "check_cortex", "target": "aggregate_results" },
    { "source": "check_postgres", "target": "aggregate_results" },
    { "source": "check_redis", "target": "aggregate_results" },
    { "source": "check_youtubedl", "target": "aggregate_results" },
    { "source": "check_persona", "target": "aggregate_results" },
    { "source": "check_whisperflow", "target": "aggregate_results" },
    { "source": "aggregate_results", "target": "check_if_failures" },
    { "source": "check_if_failures", "sourceOutput": "true", "target": "send_alert" },
    { "source": "check_if_failures", "sourceOutput": "false", "target": "log_healthy" }
  ],
  "settings": {
    "executionOrder": "parallel",
    "saveExecutionData": true,
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": null,
    "timezone": "America/Vancouver"
  },
  "tags": ["monitoring", "health", "infrastructure"]
}
